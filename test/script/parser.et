module parser

asset scripts:
    path: ../asset/parser

test Parser:
    spawn as p 
    with p:
        send "load non-existing-file.et"
        expect /load-failed file-not-found .*/

        send "load ${scripts.path}/indent.et"
        expect /load-done/

        send "load ${scripts.path}/function.et"
        expect /load-done/

        send "load ${scripts.path}/function-fail.et"
        expect /load-failed parse-error/
